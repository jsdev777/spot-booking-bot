{
  "title": "Spot Booking Bot",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "panels": [
    {
      "type": "timeseries",
      "title": "Booking Create Rate",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(spot_booking_booking_create_total[5m])) by (result)",
          "legendFormat": "{{result}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Booking Create P95/P99 (ms)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "1000 * histogram_quantile(0.95, sum(rate(spot_booking_booking_create_duration_ms_bucket[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "1000 * histogram_quantile(0.99, sum(rate(spot_booking_booking_create_duration_ms_bucket[5m])) by (le))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Slots Build P95/P99 (ms)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "1000 * histogram_quantile(0.95, sum(rate(spot_booking_booking_slots_build_duration_ms_bucket[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "1000 * histogram_quantile(0.99, sum(rate(spot_booking_booking_slots_build_duration_ms_bucket[5m])) by (le))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Reminder Batch P95/P99 (ms)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "1000 * histogram_quantile(0.95, sum(rate(spot_booking_reminder_batch_duration_ms_bucket[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "1000 * histogram_quantile(0.99, sum(rate(spot_booking_reminder_batch_duration_ms_bucket[5m])) by (le))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Telegram Sends by Result/Kind",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "sum(rate(spot_booking_telegram_send_total[5m])) by (result, kind)",
          "legendFormat": "{{kind}} {{result}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Telegram Retry Rate",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "sum(rate(spot_booking_telegram_send_retry_total[5m])) by (kind)",
          "legendFormat": "{{kind}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Process CPU Seconds",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "rate(spot_booking_process_cpu_user_seconds_total[5m]) + rate(spot_booking_process_cpu_system_seconds_total[5m])",
          "legendFormat": "cpu"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Process RSS Memory",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "targets": [
        {
          "expr": "spot_booking_process_resident_memory_bytes",
          "legendFormat": "rss"
        }
      ]
    }
  ],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" }
}
