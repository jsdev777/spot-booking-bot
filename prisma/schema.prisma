generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// Sport code (in PostgreSQL, the enum type is still called SportType)
enum SportKindCode {
  TENNIS
  FOOTBALL
  BASKETBALL
  VOLLEYBALL

  @@map("SportType")
}

/// Sports Reference Guide: Code + Description (for armor and UI)
model SportKind {
  sportKindCode SportKindCode @id @map("sport_kind_code")
  nameUa        String        @map("name_ua")
  bookings      Booking[]
  resources     ResourceSportKind[]

  @@map("sport_kinds")
}

enum BookingStatus {
  PENDING
  ACTIVE
  FINISHED
  CANCELLED
}

/// Visibility of the venue in the booking for regular chat participants
enum ResourceVisibility {
  ACTIVE
  INACTIVE

  @@map("resource_visibility")
}

model Community {
  id                     String                      @id @default(uuid())
  telegramChatId         BigInt                      @unique @map("telegram_chat_id")
  name                   String
  createdAt              DateTime                    @default(now()) @map("created_at")
  /// The time zone for the period during which regular participants can make reservations (local time). Chat admins and creators are not subject to this restriction
  bookingWindowTimeZone  String                      @default("Europe/Kyiv") @map("booking_window_time_zone")
  /// The booking window for participants is open from 12:00 AM to 11:59 PM (inclusive). Group administrators can make reservations at any time
  bookingWindowStartHour Int                         @default(0) @map("booking_window_start_hour")
  /// End of the window for participants, hours 1–24: [start, end); 24 — until midnight. Does not apply to administrators
  bookingWindowEndHour   Int                         @default(24) @map("booking_window_end_hour")
  communityResources     CommunityResource[]
  userBookingLimits      CommunityUserBookingLimit[]
  groupMemberships       GroupChatMembership[]
  rules                  CommunityRules[]

  @@map("communities")
}

/// Community rules text per language. Until rules are approved, we do not assign the member to the community in group_chat_memberships
model CommunityRules {
  communityId String    @map("community_id")
  languageId  String    @map("language_id")
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  language    Language  @relation(fields: [languageId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  text        String    @db.Text
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at")

  @@id([communityId, languageId])
  @@index([languageId])
  @@map("community_rules")
}

/// Interface/message language (i18n code, e.g., ISO 639-1)
model Language {
  id                   String                @id
  nameNative           String                @map("name_native")
  memberships          GroupChatMembership[]
  communityRules       CommunityRules[]
  telegramUsersDefault TelegramUser[]      @relation("TelegramUserDefaultLanguage")

  @@map("languages")
}

/// Telegram user (one account for all of the bot's groups)
model TelegramUser {
  id                  String                @id @default(uuid())
  telegramUserId      BigInt                @unique @map("telegram_user_id")
  username            String?               @map("username")
  firstName           String?               @map("first_name")
  lastName            String?               @map("last_name")
  /// Default UI language (private /start); overridden per group by GroupChatMembership.languageId
  defaultLanguageId   String?               @map("default_language_id")
  defaultLanguage     Language?             @relation("TelegramUserDefaultLanguage", fields: [defaultLanguageId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  createdAt           DateTime              @default(now()) @map("created_at")
  updatedAt           DateTime              @updatedAt @map("updated_at")
  memberships         GroupChatMembership[]

  @@index([defaultLanguageId])
  @@map("telegram_users")
}

/// A member of a group or supergroup that contains a bot (based on the `chat_member` update)
model GroupChatMembership {
  id                 String       @id @default(uuid())
  telegramChatId     BigInt       @map("telegram_chat_id")
  userId             String       @map("user_id")
  user               TelegramUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  communityId        String?      @map("community_id")
  community          Community?   @relation(fields: [communityId], references: [id], onDelete: SetNull)
  joinedAt           DateTime     @default(now()) @map("joined_at")
  leftAt             DateTime?    @map("left_at")
  isActive           Boolean      @default(true) @map("is_active")
  languageId         String?      @map("language_id")
  language           Language?    @relation(fields: [languageId], references: [id], onDelete: SetNull)
  /// Confirmation of review of group rules
  groupRulesAccepted Boolean      @default(false) @map("group_rules_accepted")

  @@unique([telegramChatId, userId])
  @@index([telegramChatId])
  @@index([communityId])
  @@index([isActive])
  @@index([languageId])
  @@map("group_chat_memberships")
}

/// The total number of minutes a single user (Telegram) can reserve in a group each day of the week (ISO 1–7)
/// The day of the week and calendar date are based on the platform's time zone (`Resource.timeZone`) at the time the reservation is made. null = no limit
model CommunityUserBookingLimit {
  id          String    @id @default(uuid())
  communityId String    @map("community_id")
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  weekday     Int
  maxMinutes  Int?      @map("max_minutes")

  @@unique([communityId, weekday])
  @@index([communityId])
  @@map("community_user_booking_limits")
}

/// Resource in a specific community context
model CommunityResource {
  id                        String                     @id @default(uuid())
  communityId               String                     @map("community_id")
  community                 Community                  @relation(fields: [communityId], references: [id], onDelete: Cascade)
  resourceId                String                     @map("resource_id")
  resource                  Resource                   @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  userBookingLimits         CommunityResourceUserBookingLimit[]
  bookings                  Booking[]

  @@unique([communityId, resourceId])
  @@index([communityId])
  @@index([resourceId])
  @@map("community_resources")
}

/// Daily per-user cap in a specific community+resource context (ISO weekday 1–7)
model CommunityResourceUserBookingLimit {
  id                  String            @id @default(uuid())
  communityResourceId String            @map("community_resource_id")
  communityResource   CommunityResource @relation(fields: [communityResourceId], references: [id], onDelete: Cascade)
  weekday             Int
  maxMinutes          Int?              @map("max_minutes")

  @@unique([communityResourceId, weekday])
  @@index([communityResourceId])
  @@map("community_resource_user_booking_limits")
}

model Resource {
  id           String                 @id @default(uuid())
  name         String
  address      String?
  timeZone     String                 @map("time_zone")
  visibility   ResourceVisibility     @default(ACTIVE) @map("visibility")
  communityResources CommunityResource[]
  bookings     Booking[]
  workingHours ResourceWorkingHours[]
  sportKinds   ResourceSportKind[]

  @@map("resources")
}

model ResourceSportKind {
  resourceId    String        @map("resource_id")
  sportKindCode SportKindCode @map("sport_kind_code")
  resource      Resource      @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  sportKind     SportKind     @relation(fields: [sportKindCode], references: [sportKindCode], onDelete: Restrict, onUpdate: Cascade)

  @@id([resourceId, sportKindCode])
  @@index([sportKindCode])
  @@map("resource_sport_kinds")
}

/// Site operating hours by day of the week (ISO 1 = Mon … 7 = Sun)
model ResourceWorkingHours {
  id            String   @id @default(uuid())
  resourceId    String   @map("resource_id")
  resource      Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  weekday       Int
  isClosed      Boolean  @default(false) @map("is_closed")
  slotStartHour Int?     @map("slot_start_hour")
  slotEndHour   Int?     @map("slot_end_hour")

  @@unique([resourceId, weekday])
  @@index([resourceId])
  @@map("resource_working_hours")
}

model Booking {
  id                  String                      @id @default(uuid())
  communityResourceId String                      @map("community_resource_id")
  communityResource   CommunityResource           @relation(fields: [communityResourceId], references: [id], onDelete: Cascade)
  resourceId          String                      @map("resource_id")
  resource            Resource                    @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  sportKindCode       SportKindCode               @map("sport_kind_code")
  sportKind           SportKind                   @relation(fields: [sportKindCode], references: [sportKindCode])
  userId              BigInt                      @map("user_id")
  userName            String?                     @map("user_name")
  startTime           DateTime                    @map("start_time")
  endTime             DateTime                    @map("end_time")
  status              BookingStatus               @default(PENDING)
  reminderSent        Boolean                     @default(false) @map("reminder_sent")
  isLookingForPlayers Boolean                     @default(false) @map("is_looking_for_players")
  requiredPlayers     Int                         @default(0) @map("required_players")
  createdAt           DateTime                    @default(now()) @map("created_at")
  lookingParticipants BookingLookingParticipant[]

  @@index([resourceId, status])
  @@index([communityResourceId, status])
  @@index([status, startTime])
  @@index([status, endTime])
  @@index([userId, communityResourceId, resourceId, status, startTime])
  @@map("bookings")
}

/// Who has joined the reservation via “Available Spots”: for each click, add 1 to `peopleCount` and subtract 1 from `booking.required_players`
model BookingLookingParticipant {
  id             String  @id @default(uuid())
  bookingId      String  @map("booking_id")
  booking        Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  telegramUserId BigInt  @map("telegram_user_id")

  /// How many times the user clicked the button (= how many people on their end)

  peopleCount Int @default(1) @map("people_count")

  /// ID of the last private message containing game details (remove before sending the updated text)

  lastDmMessageId Int? @map("last_dm_message_id")

  /// A reminder was sent to this participant about 15 minutes before the start

  reminderSent Boolean  @default(false) @map("reminder_sent")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@unique([bookingId, telegramUserId])
  @@index([bookingId])
  @@index([telegramUserId])
  @@map("booking_looking_participants")
}
